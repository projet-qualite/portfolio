     voir(){\n\n        console.log(\"message: \"+this.message);\n\n      },\n      \n      sendEmail(e) {\n      try {\n        console.log(\"nom: \"+this.nom+\" \"+\"email: \"+this.email+\" \"+\"sujet: \"+this.sujet+\" \"+\"message: \"+this.message+\" \");\n        emailjs.sendForm('service_yy72j9m', 'template_7se6h8f', e.target,\n        'user_PD20WWJ1nwwFegTvaNmJh', {\n          sujet: this.sujet,\n          name: this.nom,\n          message: this.message,\n          email: this.email,\n        })\n\n      } catch(error) {\n          console.log({error})\n      }\n      \n    },\n    },\n  }\n</script>"]}]}