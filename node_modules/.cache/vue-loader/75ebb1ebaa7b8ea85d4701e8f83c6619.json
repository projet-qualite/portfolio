         v-for=\"domaine in domaines\"\n                :key=\"domaine\">\n\n                  <v-row>\n                    <h3 style=\"font-family: second; color:#004B82; font-size:1rem;\" class=\"mt-4\"><b>{{ domaine.header }}</b></h3>\n                  </v-row> \n                  <v-col \n                    v-for=\"element in domaine.elements\"\n                    :key=\"element\"\n                  >\n\n                    <v-subheader>\n                      <v-row>\n                        {{ element.nom }}\n                        <v-spacer>\n                    </v-spacer>\n                        <strong>{{ Math.ceil(element.level) }}%</strong>\n\n                      </v-row>\n                        \n                    </v-subheader>\n                    \n                     \n\n                      \n                      <v-progress-linear\n                        v-model=\"element.level\"\n                        height=\"8\"\n                      >\n                      </v-progress-linear>\n                    </v-col>\n\n\n              </span>\n\n\n              \n              \n\n       </v-col>\n\n       <v-spacer></v-spacer>\n\n       <v-col>\n\n             <v-row>\n               <v-icon x-large color=\"#004B82\">mdi-bag-checked</v-icon>\n               <h3 style=\"font-family: second; color:#004B82; font-size:2rem;\" class=\"ml-4\">Langues</h3>\n             </v-row> \n\n             <v-row>\n                    <h3 style=\"font-family: second; color:#004B82; font-size:1rem;\" class=\"mt-4\"><b></b></h3>\n              </v-row>        \n\n            <span\n                v-for=\"langue in langues\"\n                :key=\"langue\">\n\n                  \n                  <v-col \n                  >\n                       <v-subheader>\n                      <v-row>\n                        {{ langue.nom }}\n                        <v-spacer>\n                    </v-spacer>\n                        <strong>{{ Math.ceil(langue.level) }}%</strong>\n\n                      </v-row>\n                        \n                    </v-subheader>\n                    \n                     \n\n                      \n                      <v-progress-linear\n                        v-model=\"langue.level\"\n                        height=\"8\"\n                      >\n                      </v-progress-linear>\n                    </v-col>\n\n\n              </span>\n\n       </v-col>\n\n       \n    \n\n    </v-row>\n\n\n  \n    \n      \n  </div>\n</template>\n\n<script>\n  export default {\n    data: () => ({\n\n      \n\n      \n       domaines: [\n          {\n          header: \"Programmation Web\",\n          elements: [\n            {\n              nom: 'PHP',\n              level: 90\n            },\n            {\n              nom: 'Vue JS',\n              level: 85\n            },\n\n            {\n              nom: 'Laravel',\n              level: 68\n            },\n\n          ]\n        },\n\n        {\n          header: \"Programmation Mobile\",\n          elements: [\n            {\n              nom: 'Flutter',\n              level: 95\n            },\n            {\n              nom: 'Java',\n              level: 80\n            },\n\n            {\n              nom: 'Kotlin',\n              level: 70\n            },\n\n          ]\n\n        }\n      \n       ],\n\n       langues: [\n         {\n           nom: \"Français\",\n           level: 100\n         }, \n\n         {\n           nom: \"Nouchi\",\n           level: 100\n         },\n\n         {\n           nom: \"Anglais\",\n           level: 65\n         },\n\n         {\n           nom: \"Allemand\",\n           level: 20\n         },\n\n       ]\n         \n            \n\n\n    }),\n    methods: {\n      // Create an array the length of our items\n      // with all values as true\n      all () {\n        this.panel = [...Array(this.items).keys()].map((k, i) => i)\n      },\n      // Reset the panel\n      none () {\n        this.panel = []\n      },\n    },\n  }\n</script>\n\n\n<style>\n.v-card--reveal {\n  align-items: center;\n  bottom: 0;\n  justify-content: center;\n  opacity: .5;\n  position: absolute;\n  width: 100%;\n}\n</style>"]}]}