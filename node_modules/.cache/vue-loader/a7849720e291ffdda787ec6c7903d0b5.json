{"remainingRequest":"/Users/kangacedricmarshallfry/portfolio/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/kangacedricmarshallfry/portfolio/src/components/Contact.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/kangacedricmarshallfry/portfolio/src/components/Contact.vue","mtime":1606308959744},{"path":"/Users/kangacedricmarshallfry/portfolio/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/kangacedricmarshallfry/portfolio/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/Users/kangacedricmarshallfry/portfolio/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/kangacedricmarshallfry/portfolio/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Contact.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAwIA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;;AAGA;;;;AAIA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;;AAEA;AACA;AACA;;;AAGA;;AAEA;;AAEA;AACA;AACA;;AAEA;;AAEA;AACA;AACA","file":"Contact.vue","sourceRoot":"src/components","sourcesContent":["<template>\n<v-container fill-height fluid class=\"grey lighten-5\">\n  <v-col align=\"center\"\n      justify=\"center\">\n      <v-col>\n        <h3 style=\"font-family: first; color:#FF9B00; font-size:3rem; margin-left: 35%; margin-right: 35%;\">Contactez moi</h3>\n      </v-col>\n\n\n  <v-form  @submit.prevent=\"sendEmail\">\n    <v-container>\n\n      <v-row>\n        <v-col\n          cols=\"12\"\n          sm=\"6\"\n        >\n          <v-text-field\n          required\n          outlined\n            label=\"Nom\"\n            :rules=\"[v => !!v || 'Nom requis']\"\n            v-model=\"name\"\n          ></v-text-field>\n\n         \n        </v-col>\n\n        <v-col\n          cols=\"12\"\n          sm=\"6\"\n        >\n          \n            \n\n            <v-text-field\n                outlined\n                label=\"Email\"\n                id=\"email2\"\n                :rules=\"emailRules\"\n                v-model=\"email\"\n            ></v-text-field>\n\n\n         \n\n          \n        </v-col>\n\n      </v-row>\n\n      <v-row>\n\n            <v-col\n            sm=\"12\"\n            >\n            <v-text-field\n                outlined\n                label=\"Sujet\"\n                v-model=\"sujet\"\n                :rules=\"[v => !!v || 'Sujet requis']\"\n            ></v-text-field>\n\n            \n            </v-col>\n\n       \n        </v-row>\n\n\n        <v-row>\n\n            <v-col\n            sm=\"12\"\n            >\n            <v-textarea\n            outlined\n            id=\"message\"\n                color=\"orange\"\n                :rules=\"[v => !!v || 'Message requis']\"\n                v-model=\"message\"\n                >\n                <template v-slot:label>\n                    <div>\n                    Message\n                    </div>\n                </template>\n                </v-textarea>\n\n            \n            </v-col>\n\n       \n        </v-row>\n\n        <v-row>\n\n            <v-col\n            sm=\"12\"\n            >\n                <v-btn\n                    @click=\"validate\"\n                    color=\"warning\"\n                    \n                    >\n                    \n                    Envoyer message\n                </v-btn>\n            \n            </v-col>\n\n       \n        </v-row>\n    </v-container>\n  </v-form>\n\n  </v-col>\n  <v-snackbar\n      v-model=\"snackbar\"\n    >\n      {{ text }}\n\n      <template v-slot:action=\"{ attrs }\">\n        <v-btn\n          color=\"orange\"\n          text\n          v-bind=\"attrs\"\n          @click=\"snackbar = false\"\n        >\n          Fermer\n        </v-btn>\n      </template>\n    </v-snackbar>\n</v-container>\n</template>\n<script>\n  import { validationMixin } from 'vuelidate'\n  import { required, maxLength, email } from 'vuelidate/lib/validators'\n  import axios from 'axios';\n\n  export default {\n    mixins: [validationMixin],\n\n    validations: {\n      name: { required, maxLength: maxLength(10) },\n      email: { required, email },\n      select: { required },\n      checkbox: {\n        checked (val) {\n          return val\n        },\n      },\n    },\n\n    data: () => ({\n      name: '',\n      email: '',\n      sujet: '',\n      message: '',\n      emailRules: [\n        v => !!v || 'E-mail est requis',\n        v => /.+@.+\\..+/.test(v) || 'E-mail invalide',\n      ],\n      snackbar: false,\n      text: `Hello, I'm a snackbar`,\n\n      \n    }),\n\n    \n\n    methods: {\n\n      validate () {\n        this.snackbar = true;\n        if(this.name === '' || this.sujet === '' || this.message === '' || !(this.email.includes(\"@\")) || !(this.email.includes(\".\")) )\n        {\n          this.snackbar = true;\n          this.text = \"Veuillez saisir tous les champs\";\n\n          if( this.$refs.form)\n          {\n            this.$refs.form.validate();\n          }\n        }\n        else{\n            \n\n            axios\n            .get('https://www.rapidkar.com/api/public/api/send2/email/'+this.email+\"/\"+this.name+\"/\"+this.sujet+\"/\"+this.message)\n            .then(response => (this.info = response));\n\n            this.snackbar = true;\n            this.text = \"Message envoyé\";\n        }\n        \n        \n      },\n\n      voir(){\n\n        console.log(\"message: \"+this.message);\n        console.log(document.getElementById(\"email\").value);\n        console.log(document.getElementById(\"email2\").value);\n\n      }\n      \n      ,\n    },\n  }\n</script>"]}]}