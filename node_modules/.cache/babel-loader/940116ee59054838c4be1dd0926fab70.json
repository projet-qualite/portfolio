                          </v-col>\n\n                          <v-textarea\n                            name=\"input-7-1\"\n                            label=\"Message\"\n                          ></v-textarea>\n                          \n                          \n                          \n                        </v-row>\n                      </v-container>\n                    </v-card-text>\n                    <v-card-actions>\n                      <v-spacer></v-spacer>\n                      <v-btn\n                        color=\"blue darken-1\"\n                        text\n                        @click=\"dialog = false\"\n                      >\n                        Fermer\n                      </v-btn>\n                      <v-btn\n                        color=\"blue darken-1\"\n                        text\n                        @click=\"dialog = false\"\n                      >\n                        Envoyer\n                      </v-btn>\n                    </v-card-actions>\n                  </v-card>\n                </v-dialog>\n              </v-row>\n\n\n\n          \n        </div>\n      </v-row>\n</template>\n\n<script>\n  export default {\n    name: \"Navbar\",\n    data: () => ({\n      dialog: false,\n      menus: [\n        {titre: 'Accueil', couleur: '#FF9803' },\n        {titre: 'Portfolio', couleur: '#0070C2' },\n        {titre: 'Projets', couleur: '#0070C2' }\n      ],\n    }),\n    methods:{\n      changerCouleur: function(identifiant)\n      {\n        for(let i = 0; i<this.menus.length; i++)\n        {\n          this.menus[i].couleur = '#0070C2';\n        }\n\n        this.menus[identifiant].couleur = '#FF9803';\n\n      }\n\n    }\n  }\n</script>\n"],"sourceRoot":"src/components"}]}